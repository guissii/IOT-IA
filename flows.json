    {
        "id": "fn-prep-ia",
        "type": "function",
        "z": "tab-smarthome",
        "name": "fn: Préparer appel IA Python",
        "func": "msg.url = 'http://ai_server:5000/predict';\nmsg.method = 'POST';\nmsg.headers = {'Content-Type': 'application/json'};\nmsg.payload = {\n    temperature: msg.payload.temperature,\n    humidity   : msg.payload.humidity\n};\nreturn msg;",
        "outputs": 1,
        "x": 420, "y": 240,
        "wires": [["http-ia"]]
    },
    {
        "id": "http-ia",
        "type": "http request",
        "z": "tab-smarthome",
        "name": "API IA Python — /predict",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "x": 650, "y": 240,
        "wires": [["fn-traiter-ia"]]
    },
    {
        "id": "fn-traiter-ia",
        "type": "function",
        "z": "tab-smarthome",
        "name": "fn: Formater résultat IA",
        "func": "var ai = msg.payload;\nvar out1 = {\n    topic: 'home/wokwi/ai/anomaly',\n    payload: JSON.stringify({ anomaly: ai.anomaly, score: ai.z_score, value: ai.temperature })\n};\nvar out2 = {\n    topic: 'home/wokwi/ai/prediction',\n    payload: JSON.stringify({ predicted_temp: ai.predicted_temp, in_minutes: ai.in_minutes })\n};\nreturn [out1, out2];",
        "outputs": 2,
        "x": 860, "y": 240,
        "wires": [["mqtt-out-anomaly"], ["mqtt-out-prediction"]]
    },
    {
        "id": "mqtt-out-anomaly",
        "type": "mqtt out",
        "z": "tab-smarthome",
        "name": "PUB home/wokwi/ai/anomaly",
        "topic": "",
        "qos": "1",
        "retain": "false",
        "broker": "broker-emqx",
        "x": 1080, "y": 220,
