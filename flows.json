    {
        "id": "fn-rule-temp",
        "type": "function",
        "z": "tab-automation",
        "name": "⚙ Règle : Temp > 30°C → Relais 1 AUTO",
        "func": "var T = msg.payload.temperature;\nvar prevState = global.get('r1_auto_state') || 'OFF';\n\nif (T > 30 && prevState !== 'ON') {\n    global.set('r1_auto_state', 'ON');\n    node.warn('AUTO: Température ' + T + '°C > 30°C — Relais 1 ON');\n    return {\n        payload: { relay: 'relais1', state: 'ON', auto: true, reason: 'T=' + T + '°C > 30°C' },\n        topic: 'home/wokwi/relay1/command'\n    };\n} else if (T <= 28 && prevState !== 'OFF') {\n    global.set('r1_auto_state', 'OFF');\n    node.warn('AUTO: Température ' + T + '°C <= 28°C — Relais 1 OFF');\n    return {\n        payload: { relay: 'relais1', state: 'OFF', auto: true, reason: 'T=' + T + '°C <= 28°C' },\n        topic: 'home/wokwi/relay1/command'\n    };\n}\nreturn null;",
        "outputs": 1,
        "x": 450, "y": 60,
        "wires": [["mqtt-out-auto-relay1", "debug-auto-r1", "text-auto-log"]]
    },
    {
        "id": "mqtt-out-auto-relay1",
        "type": "mqtt out",
        "z": "tab-automation",
        "name": "PUB AUTO → relay1/command",
        "topic": "",
        "qos": "1",
        "retain": "false",
        "broker": "broker-emqx",
        "x": 800, "y": 40,
        "wires": []
    },
    {
        "id": "debug-auto-r1",
        "type": "debug",
        "z": "tab-automation",
        "name": "Debug Auto Relais 1",
        "active": true,
        "tosidebar": true,
        "complete": "payload",
        "x": 800, "y": 80,
        "wires": []
    },

    {
        "id": "fn-rule-hum",
        "type": "function",
        "z": "tab-automation",
        "name": "⚙ Règle : Hum < 35% → Relais 2 AUTO",
        "func": "var H = msg.payload.humidity;\nvar prevState = global.get('r2_auto_state') || 'OFF';\n\nif (H < 35 && prevState !== 'ON') {\n    global.set('r2_auto_state', 'ON');\n    node.warn('AUTO: Humidité ' + H + '% < 35% — Relais 2 ON (humidificateur)');\n    return {\n        payload: { relay: 'relais2', state: 'ON', auto: true, reason: 'H=' + H + '% < 35%' },\n        topic: 'home/wokwi/relay2/command'\n    };\n} else if (H >= 40 && prevState !== 'OFF') {\n    global.set('r2_auto_state', 'OFF');\n    node.warn('AUTO: Humidité ' + H + '% >= 40% — Relais 2 OFF');\n    return {\n        payload: { relay: 'relais2', state: 'OFF', auto: true, reason: 'H=' + H + '% >= 40%' },\n        topic: 'home/wokwi/relay2/command'\n    };\n}\nreturn null;",
        "outputs": 1,
        "x": 450, "y": 160,
        "wires": [["mqtt-out-auto-relay2", "debug-auto-r2", "text-auto-log"]]
    },
